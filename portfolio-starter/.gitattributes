# Normalize line endings across OSes.
* text=auto eol=lf

# Mark binary asset types explicitly.
*.glb   binary
*.hdr   binary
*.wasm  binary
*.webp  binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.mp4   binary
*.woff  binary
*.woff2 binary

# Hide generated files from GitHub language statistics.
package-lock.json linguist-generated=true
dist/**           linguist-generated=true
