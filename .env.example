# Copy this file to .env and fill in the values.
# .env is gitignored — never commit it.

# Required in production: a long random string (e.g. `python -c "import secrets; print(secrets.token_hex(32))"`)
SECRET_KEY=

# Optional: override the default SQLite path with a PostgreSQL URL for production
# DATABASE_URL=postgresql://user:password@localhost/retinoguard
